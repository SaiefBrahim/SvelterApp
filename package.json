{
	"name": "svelterapp",
	"version": "0.0.1",
	"description": "A modern, production-ready SvelteKit dashboard starter with fully functional Role-Based Access Control (RBAC)",
	"type": "module",
	"keywords": [
		"svelte",
		"sveltekit",
		"dashboard",
		"rbac",
		"role-based-access-control",
		"authentication",
		"multi-tenant",
		"saas",
		"starter",
		"template",
		"typescript",
		"prisma",
		"tailwindcss",
		"shadcn"
	],
	"author": "SaiefBrahim",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/SaiefBrahim/SvelterApp.git"
	},
	"bugs": {
		"url": "https://github.com/SaiefBrahim/SvelterApp/issues"
	},
	"homepage": "https://github.com/SaiefBrahim/SvelterApp#readme",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:generate": "prisma generate",
		"db:push": "prisma db push",
		"db:migrate": "prisma migrate dev",
		"db:seed": "npx tsx prisma/seed.ts",
		"db:studio": "prisma studio",
		"db:reset": "prisma migrate reset --force",
		"lang:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide"
	},
	"devDependencies": {
		"@internationalized/date": "^3.10.1",
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/bcryptjs": "^2.4.6",
		"@types/node": "^25.0.8",
		"@types/pg": "^8.16.0",
		"bits-ui": "^2.15.4",
		"clsx": "^2.1.1",
		"mode-watcher": "^1.1.0",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"svelte-sonner": "^1.0.7",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.2.6"
	},
	"dependencies": {
		"@auth/prisma-adapter": "^2.11.1",
		"@auth/sveltekit": "^1.11.1",
		"@inlang/paraglide-js": "^1.11.8",
		"@prisma/adapter-pg": "^7.2.0",
		"@prisma/client": "^7.2.0",
		"@tailwindcss/vite": "^4.1.18",
		"bcryptjs": "^3.0.3",
		"dotenv": "^17.2.3",
		"formsnap": "^2.0.1",
		"pg": "^8.17.0",
		"prisma": "^7.2.0",
		"resend": "^6.7.0",
		"sveltekit-superforms": "^2.29.1",
		"tailwindcss": "^4.1.18",
		"zod": "4.3.5"
	}
}
